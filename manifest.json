{
    "manifest_version": 3,
    "name": "fast-learn",
    "description": "Fast learning with AI (Google Gemini and OpenAI-compatible providers like GLM/Z.AI, OpenRouter). Explain selected text or whole page.",
    "version": "2.4.0",
    "permissions": [
        "contextMenus",
        "activeTab",
        "scripting",
        "tabs",
        "system.display",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "scripts/background.js"
    },
    "action": {
        "default_title": "fast-learn"
    },
    "options_page": "options/options.html",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "commands": {
        "fast-learn-lookup": {
            "suggested_key": {
                "default": "Ctrl+Shift+Q",
                "mac": "Command+Shift+Q"
            },
            "description": "Открыть fast-learn для выделенного текста или страницы"
        }
    }
}